---
import type { Translations } from "../i18n/fr";
interface Props { t: Translations; lang: string; }
const { t, lang } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="bg-[#151515] py-16 px-6">
  <div class="max-w-7xl mx-auto">
    <!-- Top row -->
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-8 pb-10 border-b border-white/8">
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 bg-[#EE0000] flex items-center justify-center rounded">
          <svg width="16" height="16" viewBox="0 0 14 14" fill="none">
            <rect x="1" y="1" width="5" height="5" rx="1" fill="white"/>
            <rect x="8" y="1" width="5" height="5" rx="1" fill="white"/>
            <rect x="1" y="8" width="5" height="5" rx="1" fill="white"/>
            <rect x="8" y="8" width="5" height="5" rx="1" fill="white" opacity="0.5"/>
          </svg>
        </div>
        <div>
          <p class="font-bold text-white text-[15px] tracking-tight">Jamono<span class="font-light"> Inc.</span></p>
          <p class="text-xs text-white/40 mt-0.5">{t.footer.tagline}</p>
        </div>
      </div>

      <nav class="flex flex-wrap gap-8">
        <a href="#products" class="text-sm text-white/50 hover:text-white transition-colors duration-200">{t.nav.products}</a>
        <a href="#services" class="text-sm text-white/50 hover:text-white transition-colors duration-200">{t.nav.services}</a>
        <a href="#about" class="text-sm text-white/50 hover:text-white transition-colors duration-200">{t.nav.about}</a>
        <a href="#contact" class="text-sm text-white/50 hover:text-white transition-colors duration-200">{t.nav.contact}</a>
        <a href={lang === "fr" ? "/en" : "/"} class="text-sm text-white/50 hover:text-[#EE0000] transition-colors duration-200 uppercase">{lang === "fr" ? "EN" : "FR"}</a>
      </nav>
    </div>

    <!-- Products row -->
    <div class="flex flex-wrap gap-6 py-8 border-b border-white/8">
      <a href="https://gobering.com" target="_blank" rel="noopener" class="text-sm text-white/40 hover:text-[#EE0000] transition-colors duration-200">Gobering</a>
      <span class="text-sm text-white/20">Golamda</span>
      <span class="text-sm text-white/20">LexBook</span>
    </div>

    <!-- Bottom -->
    <div class="pt-8">
      <p class="text-xs text-white/30">© {year} Jamono Inc. — {t.footer.rights}</p>
    </div>
  </div>
</footer>
