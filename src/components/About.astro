---
import type { Translations } from "../i18n/fr";
interface Props { t: Translations; }
const { t } = Astro.props;
const paragraphs = t.about.text.split("\n\n");
---

<section id="about" class="py-28 px-6 bg-[#f5f5f5] border-t border-black/6">
  <div class="max-w-7xl mx-auto">
    <div class="grid md:grid-cols-2 gap-20 items-center">
      <div class="reveal">
        <p class="text-xs uppercase tracking-widest text-[#EE0000] font-semibold mb-3">{t.about.title}</p>
        <div class="space-y-4">
          {paragraphs.map(p => (
            <p class="text-[#444] leading-relaxed text-[15px]">{p}</p>
          ))}
        </div>
      </div>

      <div class="reveal space-y-3">
        {t.about.values.map((value, i) => (
          <div
            class="flex items-center gap-4 p-5 bg-white border border-black/6 hover:border-[#EE0000]/25 transition-colors duration-300 rounded"
            style={`animation-delay: ${i * 80}ms`}
          >
            <div class="w-8 h-8 bg-[#EE0000] flex items-center justify-center flex-shrink-0 rounded">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                <path d="M2.5 7l3 3 6-6" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <span class="text-sm font-semibold text-[#151515]">{value}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
