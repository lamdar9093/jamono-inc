---
import type { Translations } from "../i18n/fr";
interface Props { t: Translations; }
const { t } = Astro.props;

const icons: Record<string, string> = {
  wrench: `<path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>`,
  support: `<path d="M3 18v-6a9 9 0 0118 0v6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M21 19a2 2 0 01-2 2h-1a2 2 0 01-2-2v-3a2 2 0 012-2h3zM3 19a2 2 0 002 2h1a2 2 0 002-2v-3a2 2 0 00-2-2H3z" stroke="currentColor" stroke-width="1.5"/>`,
  training: `<path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2zM22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>`,
  cloud: `<path d="M18 10h-1.26A8 8 0 109 20h9a5 5 0 000-10z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>`,
};
---

<section id="services" class="py-28 px-6 bg-white border-t border-black/6">
  <div class="max-w-7xl mx-auto">
    <div class="mb-14 reveal">
      <p class="text-xs uppercase tracking-widest text-[#EE0000] font-semibold mb-3">{t.services.title}</p>
      <h2 class="text-3xl md:text-4xl font-bold text-[#151515] tracking-tight max-w-xl">{t.services.subtitle}</h2>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {t.services.items.map((service, i) => (
        <div
          class="reveal group p-7 border border-black/8 bg-white hover:border-[#EE0000]/30 hover:shadow-sm transition-all duration-300 rounded"
          style={`animation-delay: ${i * 60}ms`}
        >
          <div class="w-10 h-10 bg-[#EE0000]/8 flex items-center justify-center mb-5 group-hover:bg-[#EE0000]/15 transition-colors duration-300 text-[#EE0000] rounded">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" set:html={icons[service.icon]} />
          </div>
          <h3 class="text-sm font-bold text-[#151515] mb-2">{service.title}</h3>
          <p class="text-sm text-[#555] leading-relaxed">{service.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
