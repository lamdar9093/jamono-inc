---
import type { Translations } from "../i18n/fr";
interface Props { t: Translations; }
const { t } = Astro.props;
---

<section id="contact" class="py-28 px-6 bg-white border-t border-black/6">
  <div class="max-w-7xl mx-auto">
    <div class="grid md:grid-cols-2 gap-20 items-center">

      <div class="reveal">
        <p class="text-xs uppercase tracking-widest text-[#EE0000] font-semibold mb-3">{t.nav.contact}</p>
        <h2 class="text-3xl md:text-4xl font-bold text-[#151515] tracking-tight mb-4">{t.contact.title}</h2>
        <p class="text-[#555] text-[15px] leading-relaxed mb-8">{t.contact.subtitle}</p>
        <a
          href={`mailto:${t.contact.email}`}
          class="inline-flex items-center gap-3 bg-[#EE0000] text-white text-sm font-bold px-6 py-3.5 hover:bg-[#CC0000] transition-colors duration-200 rounded"
        >
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M2 4l6 5 6-5M2 4h12v8a1 1 0 01-1 1H3a1 1 0 01-1-1V4z" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          {t.contact.email}
        </a>
      </div>

      <!-- Bloc visuel droit -->
      <div class="reveal grid grid-cols-2 gap-4">
        {[
          { icon: "⚡", label: t.contact.card_response },
          { icon: "🌐", label: t.contact.card_bilingual },
          { icon: "🛠️", label: t.contact.card_tech },
          { icon: "🤝", label: t.contact.card_human },
        ].map(({ icon, label }) => (
          <div class="p-6 border border-black/8 rounded hover:border-[#EE0000]/30 transition-colors duration-300 flex flex-col gap-3">
            <span class="text-2xl">{icon}</span>
            <span class="text-sm font-semibold text-[#151515] leading-snug">{label}</span>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>
