---
import type { Translations } from "../i18n/fr";
interface Props { t: Translations; }
const { t } = Astro.props;
---

<section id="contact" class="py-28 px-6 bg-white border-t border-black/6">
  <div class="max-w-7xl mx-auto">
    <div class="grid md:grid-cols-2 gap-20 items-start">
      <div class="reveal">
        <p class="text-xs uppercase tracking-widest text-[#EE0000] font-semibold mb-3">{t.nav.contact}</p>
        <h2 class="text-3xl md:text-4xl font-bold text-[#151515] tracking-tight mb-4">{t.contact.title}</h2>
        <p class="text-[#555] text-[15px] leading-relaxed mb-8">{t.contact.subtitle}</p>
        <a
          href={`mailto:${t.contact.email}`}
          class="inline-flex items-center gap-2 text-sm font-semibold text-[#EE0000] hover:text-[#CC0000] transition-colors duration-200"
        >
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M2 4l6 5 6-5M2 4h12v8a1 1 0 01-1 1H3a1 1 0 01-1-1V4z" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          {t.contact.email}
        </a>
      </div>

      <div class="reveal">
        <form class="space-y-4" action={`mailto:${t.contact.email}`} method="get">
          <input
            type="text"
            name="name"
            placeholder={t.contact.placeholder_name}
            required
            class="w-full bg-white border border-black/12 px-4 py-3.5 text-sm text-[#151515] placeholder-[#aaa] focus:outline-none focus:border-[#EE0000] transition-colors duration-200 rounded"
          />
          <input
            type="email"
            name="email"
            placeholder={t.contact.placeholder_email}
            required
            class="w-full bg-white border border-black/12 px-4 py-3.5 text-sm text-[#151515] placeholder-[#aaa] focus:outline-none focus:border-[#EE0000] transition-colors duration-200 rounded"
          />
          <textarea
            name="message"
            placeholder={t.contact.placeholder_message}
            rows={5}
            required
            class="w-full bg-white border border-black/12 px-4 py-3.5 text-sm text-[#151515] placeholder-[#aaa] focus:outline-none focus:border-[#EE0000] transition-colors duration-200 resize-none rounded"
          ></textarea>
          <button
            type="submit"
            class="w-full bg-[#EE0000] text-white text-sm font-bold px-6 py-4 hover:bg-[#CC0000] transition-colors duration-200 rounded"
          >
            {t.contact.cta}
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
